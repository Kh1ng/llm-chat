import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';
import { invoke } from '@tauri-apps/api/core';
import { toast } from 'sonner';

// Mock Tauri invoke
vi.mock('@tauri-apps/api/core', () => ({
  invoke: vi.fn(),
}));

// Mock toast
vi.mock('sonner', () => ({
  toast: {
    success: vi.fn(),
    error: vi.fn(),
  },
}));

// Mock FileReader and file APIs
global.FileReader = class FileReader {
  result: string | ArrayBuffer | null = null;
  error: any = null;
  readyState: number = 0;
  onload: ((this: FileReader, ev: ProgressEvent<FileReader>) => any) | null = null;
  onloadend: ((this: FileReader, ev: ProgressEvent<FileReader>) => any) | null = null;
  onerror: ((this: FileReader, ev: ProgressEvent<FileReader>) => any) | null = null;

  readAsArrayBuffer(file: Blob) {
    setTimeout(() => {
      this.readyState = 2; // DONE
      if (file instanceof File) {
        // Mock file content based on file type
        if (file.name.endsWith('.txt')) {
          this.result = new TextEncoder().encode('Test file content').buffer;
        } else if (file.name.endsWith('.pdf')) {
          // Mock PDF binary content
          this.result = new Uint8Array([37, 80, 68, 70]).buffer; // "%PDF"
        } else {
          this.result = new ArrayBuffer(0);
        }
      }
      if (this.onload) {
        this.onload({ target: this } as ProgressEvent<FileReader>);
      }
    }, 10);
  }

  readAsText(file: Blob) {
    setTimeout(() => {
      this.readyState = 2; // DONE
      this.result = file instanceof File && file.name.endsWith('.txt') 
        ? 'Test file content' 
        : '';
      if (this.onload) {
        this.onload({ target: this } as ProgressEvent<FileReader>);
      }
    }, 10);
  }

  addEventListener() {}
  removeEventListener() {}
  dispatchEvent(): boolean { return true; }
};

// Mock File API
global.File = class File extends Blob {
  name: string;
  lastModified: number;
  size: number;

  constructor(fileBits: BlobPart[], fileName: string, options?: FilePropertyBag) {
    super(fileBits, options);
    this.name = fileName;
    this.lastModified = options?.lastModified || Date.now();
    this.size = fileBits.reduce((acc, part) => {
      if (typeof part === 'string') return acc + part.length;
      if (part instanceof ArrayBuffer) return acc + part.byteLength;
      if (part instanceof Uint8Array) return acc + part.length;
      return acc;
    }, 0);
  }

  arrayBuffer(): Promise<ArrayBuffer> {
    return Promise.resolve(
      this.name.endsWith('.txt') 
        ? new TextEncoder().encode('Test file content').buffer
        : this.name.endsWith('.pdf')
        ? new Uint8Array([37, 80, 68, 70]).buffer // "%PDF"
        : new ArrayBuffer(0)
    );
  }
};

// Helper function to create mock files
function createMockFile(name: string, content: string, type: string = 'text/plain'): File {
  return new File([content], name, { type });
}

describe('Document Upload Functionality', () => {
  const mockProfile = {
    name: 'Test Profile',
    address: '192.168.1.100',
    port: 11434,
    auth: null,
  };

  beforeEach(() => {
    vi.clearAllMocks();
  });

  afterEach(() => {
    vi.restoreAllMocks();
  });

  describe('File Type Validation', () => {
    it('should accept TXT files', async () => {
      const file = createMockFile('test.txt', 'Test content', 'text/plain');
      
      // Mock successful upload
      (invoke as any).mockResolvedValue('doc-123');

      // Simulate the upload process
      const fileContent = await file.arrayBuffer();
      const fileBytes = Array.from(new Uint8Array(fileContent));

      await invoke('upload_document', {
        fileContent: fileBytes,
        filename: file.name,
        llmAddress: mockProfile.address,
        llmPort: mockProfile.port,
        auth: mockProfile.auth,
      });

      expect(invoke).toHaveBeenCalledWith('upload_document', {
        fileContent: expect.any(Array),
        filename: 'test.txt',
        llmAddress: '192.168.1.100',
        llmPort: 11434,
        auth: null,
      });
    });

    it('should accept PDF files', async () => {
      const file = createMockFile('document.pdf', '%PDF-1.4 test', 'application/pdf');
      
      // Mock successful upload
      (invoke as any).mockResolvedValue('doc-456');

      const fileContent = await file.arrayBuffer();
      const fileBytes = Array.from(new Uint8Array(fileContent));

      await invoke('upload_document', {
        fileContent: fileBytes,
        filename: file.name,
        llmAddress: mockProfile.address,
        llmPort: mockProfile.port,
        auth: mockProfile.auth,
      });

      expect(invoke).toHaveBeenCalledWith('upload_document', {
        fileContent: expect.any(Array),
        filename: 'document.pdf',
        llmAddress: '192.168.1.100',
        llmPort: 11434,
        auth: null,
      });
    });

    it('should reject unsupported file types', () => {
      const unsupportedTypes = [
        'test.docx',
        'image.jpg', 
        'script.js',
        'data.csv',
        'presentation.pptx'
      ];

      unsupportedTypes.forEach(filename => {
        const fileExtension = filename.split('.').pop()?.toLowerCase();
        const allowedTypes = ['pdf', 'txt'];
        
        expect(allowedTypes.includes(fileExtension!)).toBe(false);
      });
    });
  });

  describe('File Content Processing', () => {
    it('should correctly read TXT file content as bytes', async () => {
      const testContent = 'Hello, this is test content for a text file.';
      const file = createMockFile('test.txt', testContent, 'text/plain');
      
      const fileContent = await file.arrayBuffer();
      const fileBytes = Array.from(new Uint8Array(fileContent));

      // Verify the bytes represent the original text
      const decodedText = new TextDecoder().decode(new Uint8Array(fileBytes));
      expect(decodedText).toBe(testContent);
    });

    it('should handle empty files', async () => {
      const file = createMockFile('empty.txt', '', 'text/plain');
      
      const fileContent = await file.arrayBuffer();
      const fileBytes = Array.from(new Uint8Array(fileContent));

      expect(fileBytes).toHaveLength(0);
    });

    it('should handle large files', async () => {
      const largeContent = 'x'.repeat(10000); // 10KB of text
      const file = createMockFile('large.txt', largeContent, 'text/plain');
      
      const fileContent = await file.arrayBuffer();
      const fileBytes = Array.from(new Uint8Array(fileContent));

      expect(fileBytes).toHaveLength(10000);
    });
  });

  describe('Backend Integration', () => {
    it('should call upload_document with correct parameters', async () => {
      const file = createMockFile('test.txt', 'Test content', 'text/plain');
      (invoke as any).mockResolvedValue('doc-789');

      const fileContent = await file.arrayBuffer();
      const fileBytes = Array.from(new Uint8Array(fileContent));

      await invoke('upload_document', {
        fileContent: fileBytes,
        filename: file.name,
        llmAddress: mockProfile.address,
        llmPort: mockProfile.port,
        auth: mockProfile.auth,
      });

      expect(invoke).toHaveBeenCalledTimes(1);
      expect(invoke).toHaveBeenCalledWith('upload_document', {
        fileContent: expect.any(Array),
        filename: 'test.txt',
        llmAddress: '192.168.1.100',
        llmPort: 11434,
        auth: null,
      });
    });

    it('should handle upload errors gracefully', async () => {
      const file = createMockFile('test.txt', 'Test content', 'text/plain');
      const errorMessage = 'Failed to process document';
      
      (invoke as any).mockRejectedValue(new Error(errorMessage));

      const fileContent = await file.arrayBuffer();
      const fileBytes = Array.from(new Uint8Array(fileContent));

      await expect(
        invoke('upload_document', {
          fileContent: fileBytes,
          filename: file.name,
          llmAddress: mockProfile.address,
          llmPort: mockProfile.port,
          auth: mockProfile.auth,
        })
      ).rejects.toThrow(errorMessage);
    });

    it('should include authentication when provided', async () => {
      const profileWithAuth = {
        ...mockProfile,
        auth: {
          type: 'bearer',
          value: 'test-token',
          header_name: 'Authorization'
        }
      };

      const file = createMockFile('test.txt', 'Test content', 'text/plain');
      (invoke as any).mockResolvedValue('doc-with-auth');

      const fileContent = await file.arrayBuffer();
      const fileBytes = Array.from(new Uint8Array(fileContent));

      await invoke('upload_document', {
        fileContent: fileBytes,
        filename: file.name,
        llmAddress: profileWithAuth.address,
        llmPort: profileWithAuth.port,
        auth: profileWithAuth.auth,
      });

      expect(invoke).toHaveBeenCalledWith('upload_document', {
        fileContent: expect.any(Array),
        filename: 'test.txt',
        llmAddress: '192.168.1.100',
        llmPort: 11434,
        auth: {
          type: 'bearer',
          value: 'test-token',
          header_name: 'Authorization'
        },
      });
    });
  });

  describe('Cross-Platform Compatibility', () => {
    it('should work with different path separators', () => {
      const windowsPath = 'C:\\Users\\test\\document.txt';
      const unixPath = '/home/user/document.txt';
      const macPath = '/Users/user/document.txt';

      [windowsPath, unixPath, macPath].forEach(path => {
        const filename = path.split(/[/\\]/).pop()!;
        expect(filename).toBe('document.txt');
        
        const extension = filename.split('.').pop()?.toLowerCase();
        expect(extension).toBe('txt');
      });
    });

    it('should handle unicode filenames', () => {
      const unicodeFilenames = [
        'тест.txt', // Cyrillic
        '测试.txt', // Chinese
        'テスト.txt', // Japanese
        'prueba_café.txt', // Spanish with accent
        'файл_данных.txt', // Mixed
      ];

      unicodeFilenames.forEach(filename => {
        const extension = filename.split('.').pop()?.toLowerCase();
        expect(extension).toBe('txt');
      });
    });

    it('should handle various file sizes', async () => {
      const testCases = [
        { name: 'tiny.txt', size: 1 },
        { name: 'small.txt', size: 100 },
        { name: 'medium.txt', size: 10000 },
        { name: 'large.txt', size: 100000 },
      ];

      for (const testCase of testCases) {
        const content = 'x'.repeat(testCase.size);
        const file = createMockFile(testCase.name, content, 'text/plain');
        
        const fileContent = await file.arrayBuffer();
        const fileBytes = Array.from(new Uint8Array(fileContent));

        expect(fileBytes).toHaveLength(testCase.size);
      }
    });
  });

  describe('Error Scenarios', () => {
    it('should handle network errors', async () => {
      const file = createMockFile('test.txt', 'Test content', 'text/plain');
      (invoke as any).mockRejectedValue(new Error('Network error'));

      const fileContent = await file.arrayBuffer();
      const fileBytes = Array.from(new Uint8Array(fileContent));

      await expect(
        invoke('upload_document', {
          fileContent: fileBytes,
          filename: file.name,
          llmAddress: mockProfile.address,
          llmPort: mockProfile.port,
          auth: mockProfile.auth,
        })
      ).rejects.toThrow('Network error');
    });

    it('should handle server errors', async () => {
      const file = createMockFile('test.txt', 'Test content', 'text/plain');
      (invoke as any).mockRejectedValue(new Error('Server error: 500'));

      const fileContent = await file.arrayBuffer();
      const fileBytes = Array.from(new Uint8Array(fileContent));

      await expect(
        invoke('upload_document', {
          fileContent: fileBytes,
          filename: file.name,
          llmAddress: mockProfile.address,
          llmPort: mockProfile.port,
          auth: mockProfile.auth,
        })
      ).rejects.toThrow('Server error: 500');
    });

    it('should handle authentication errors', async () => {
      const file = createMockFile('test.txt', 'Test content', 'text/plain');
      (invoke as any).mockRejectedValue(new Error('Unauthorized'));

      const fileContent = await file.arrayBuffer();
      const fileBytes = Array.from(new Uint8Array(fileContent));

      await expect(
        invoke('upload_document', {
          fileContent: fileBytes,
          filename: file.name,
          llmAddress: mockProfile.address,
          llmPort: mockProfile.port,
          auth: mockProfile.auth,
        })
      ).rejects.toThrow('Unauthorized');
    });

    it('should handle corrupted files', async () => {
      const file = createMockFile('corrupted.pdf', 'Not a real PDF', 'application/pdf');
      (invoke as any).mockRejectedValue(new Error('Failed to extract PDF text: Invalid PDF format'));

      const fileContent = await file.arrayBuffer();
      const fileBytes = Array.from(new Uint8Array(fileContent));

      await expect(
        invoke('upload_document', {
          fileContent: fileBytes,
          filename: file.name,
          llmAddress: mockProfile.address,
          llmPort: mockProfile.port,
          auth: mockProfile.auth,
        })
      ).rejects.toThrow('Failed to extract PDF text: Invalid PDF format');
    });
  });

  describe('Document Management', () => {
    it('should handle document listing', async () => {
      const mockDocuments = [
        {
          id: 'doc-1',
          filename: 'test1.txt',
          file_type: 'txt',
          file_size: 100,
          uploaded_at: new Date().toISOString(),
        },
        {
          id: 'doc-2',
          filename: 'test2.pdf',
          file_type: 'pdf',
          file_size: 2048,
          uploaded_at: new Date().toISOString(),
        },
      ];

      (invoke as any).mockResolvedValue(mockDocuments);

      const documents = await invoke('get_documents');
      
      expect(documents).toHaveLength(2);
      expect(documents[0]).toHaveProperty('filename', 'test1.txt');
      expect(documents[1]).toHaveProperty('filename', 'test2.pdf');
    });

    it('should handle document deletion', async () => {
      (invoke as any).mockResolvedValue(null);

      await invoke('delete_document', { documentId: 'doc-123' });

      expect(invoke).toHaveBeenCalledWith('delete_document', {
        documentId: 'doc-123',
      });
    });

    it('should handle document search', async () => {
      const mockSearchResults = [
        {
          id: 'chunk-1',
          document_id: 'doc-1',
          content: 'relevant text content',
          filename: 'test.txt',
          similarity: 0.85,
        },
      ];

      (invoke as any).mockResolvedValue(mockSearchResults);

      const results = await invoke('search_documents', {
        query: 'test query',
        limit: 5,
        llmAddress: mockProfile.address,
        llmPort: mockProfile.port,
        auth: mockProfile.auth,
      });

      expect(results).toHaveLength(1);
      expect(results[0]).toHaveProperty('similarity', 0.85);
    });
  });

  describe('Performance Tests', () => {
    it('should handle multiple concurrent uploads', async () => {
      const files = Array.from({ length: 5 }, (_, i) => 
        createMockFile(`test${i}.txt`, `Content ${i}`, 'text/plain')
      );

      (invoke as any).mockResolvedValue('success');

      const uploadPromises = files.map(async (file) => {
        const fileContent = await file.arrayBuffer();
        const fileBytes = Array.from(new Uint8Array(fileContent));
        
        return invoke('upload_document', {
          fileContent: fileBytes,
          filename: file.name,
          llmAddress: mockProfile.address,
          llmPort: mockProfile.port,
          auth: mockProfile.auth,
        });
      });

      await Promise.all(uploadPromises);
      expect(invoke).toHaveBeenCalledTimes(5);
    });

    it('should process files efficiently', async () => {
      const startTime = Date.now();
      
      const file = createMockFile('performance.txt', 'x'.repeat(50000), 'text/plain');
      const fileContent = await file.arrayBuffer();
      const fileBytes = Array.from(new Uint8Array(fileContent));

      const processingTime = Date.now() - startTime;
      
      expect(processingTime).toBeLessThan(1000); // Should complete in under 1 second
      expect(fileBytes).toHaveLength(50000);
    });
  });
});
